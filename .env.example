# ============================================================
#  POSPAY - Sistem Informasi Keuangan Sekolah
#  Copy this file to server/.env and fill in the values.
# ============================================================

# ---- Server ----
NODE_ENV=development
PORT=4000
# Bind semua interface (IPv4) agar port-forward / cloud agent menjangkau API
HOST=0.0.0.0
# Comma separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:5173,http://localhost:5174

# ---- Database (PostgreSQL) ----
# Dipakai Prisma + bisa dibuka di pgAdmin 4 (Register → Server):
#   Host: 127.0.0.1   Port: 5433   Database: db_sikes
#   Username: postgres   Password: db123
# Query Tool: tabel asli Prisma ("Bill","Payment","Student",…) ATAU view Indonesia:
#   SELECT * FROM tagihan; SELECT * FROM pembayaran; SELECT * FROM siswa;
#   (buat view: psql … -f server/scripts/pgadmin-readable-views.sql)
# Jangan jalankan migrate reset / hapus DB kecuali diminta eksplisit.
DATABASE_URL="postgresql://postgres:db123@127.0.0.1:5433/db_sikes?schema=public"

# ---- Bendahara registration (developer testing) ----
# Set true to allow register CRUD testing even after first bendahara exists
REGISTRATION_ALWAYS_OPEN=true
# false = jangan auto-buat akun bendahara saat seed (daftar lewat /register)
SEED_DEFAULT_BENDAHARA=false
# false = jangan tanam siswa contoh (siap uji CRUD Tambah Siswa)
SEED_SAMPLE_STUDENTS=false

# ---- School Gmail verification ----
SCHOOL_NAME="SMP Pusponegoro Brebes"
SCHOOL_EMAIL_DOMAIN=smppusponegoro.sch.id
SCHOOL_GMAIL_ADDRESS=smppusponegorobrebess@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smppusponegorobrebess@gmail.com
# App Password Gmail aktif (nama app: pospay) — 16 karakter, spasi boleh (dinormalisasi)
# Buat di https://myaccount.google.com/apppasswords lalu isi SMTP_PASS di server/.env (jangan commit password)
SMTP_PASS="xxxx xxxx xxxx xxxx"
# Alias opsional: GMAIL_APP_PASSWORD=
# Jika App Password gagal (error 535), gunakan OAuth2:
# SMTP_AUTH_TYPE=oauth2
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# Fallback email (jika SMTP 535): Google Apps Script — lihat server/scripts/gmail-apps-script/Code.gs
# GMAIL_WEBHOOK_URL=
# GMAIL_WEBHOOK_TOKEN=
# RESEND_API_KEY=
# RESEND_FROM=POSPAY <onboarding@resend.dev>

FRONTEND_BENDAHARA_URL=http://127.0.0.1:5173

# ---- JWT Auth ----
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Default password for newly created student accounts ----
STUDENT_DEFAULT_PASSWORD=siswa123

# ---- File uploads ----
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ---- Backups ----
BACKUP_DIR=backups

# ---- Google Gemini (AI Chatbot) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Firebase Cloud Messaging (Push Notifications) ----
# Path to a Firebase service account JSON file (server side)
FIREBASE_SERVICE_ACCOUNT_PATH=
# Or provide the JSON content directly (base64 encoded)
FIREBASE_SERVICE_ACCOUNT_BASE64=

# ---- Reminder scheduler (node-cron) ----
# Cron expression. Default: every day at 08:00
REMINDER_CRON="0 8 * * *"
REMINDER_ENABLED=true
# Number of days before due date to start reminding
REMINDER_DAYS_BEFORE=3

# ---- Midtrans SNAP Sandbox (wajib untuk QRIS bisa di-scan e-wallet/bank) ----
# Dapatkan Server Key & Client Key dari https://dashboard.sandbox.midtrans.com/settings/config_info
# QRIS EMV (000201…) hanya dihasilkan oleh API Midtrans — bukan QR lokal POSPAY.
# Settlement ke rekening BNI 6513009817 dikonfigurasi di dashboard Midtrans merchant.
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_CALLBACK_URL=http://127.0.0.1:4000/api/payment/webhook
# true = tampilkan QR demo lokal jika key belum valid (TIDAK bisa di-scan QRIS Tap)
MIDTRANS_SANDBOX_FALLBACK=true

# ============================================================
#  Frontend apps (apps/bendahara/.env & apps/siswa/.env)
# ============================================================
# VITE_API_BASE_URL=http://localhost:4000/api
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=

# ---- Kapasitas API (banyak permintaan / jangkauan jauh) ----
HOST=0.0.0.0
API_RATE_LIMIT_MAX=5000
AUTH_RATE_LIMIT_MAX=200
HTTP_KEEP_ALIVE_MS=65000
HTTP_REQUEST_TIMEOUT_MS=120000
